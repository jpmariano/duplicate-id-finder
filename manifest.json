{
  "manifest_version": 3,
  "name": "Duplicate ID Visual Finder",
  "version": "1.0.0",
  "description": "Finds duplicate HTML IDs and visually highlights them on the current webpage.",
  "author": "John Paul Mariano",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "Duplicate ID Visual Finder",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}